POSTGRES_DB=kb_new
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=kb_password
POSTGRES_PORT=5432

# Non-superuser role the app's ORM sessions use so Postgres RLS applies (create it with
# `pnpm run db:app-role`). Leave APP_DATABASE_URL unset to run ORM sessions as the
# superuser above — the ORM tenant-filter still enforces isolation, but RLS is dormant.
APP_DB_PASSWORD=kb_app_password
# APP_DATABASE_URL=postgresql+psycopg://kb_app:kb_app_password@localhost:5432/kb_new

# Auth: HS256 signing secret for access tokens — MUST be overridden with a long random
# value in every real environment.
JWT_SECRET=dev-insecure-change-me-in-every-real-environment-0123456789
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# While true, requests with no valid token fall back to the seeded default tenant (keeps
# the pre-auth frontend working during rollout). Set false once clients authenticate.
TENANCY_DEFAULT_FALLBACK=true
# A browser login is only accepted when its Origin host matches the tenant domain (so a
# login for acme.test only works when served from acme.test). Hosts in the bypass list and
# requests with no Origin (server-to-server / tests) skip the check.
ENFORCE_LOGIN_ORIGIN=true
LOGIN_ORIGIN_DEV_BYPASS=localhost,127.0.0.1
# TTL (seconds) of the single-use cross-domain handoff code minted after register.
HANDOFF_CODE_TTL_SECONDS=60

# Cache (Valkey)
CACHE_URL=redis://localhost:6379/0
CACHE_PORT=6379

API_PORT=8000
WEB_PORT=3000
WEBSITE_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:8000
# Where the marketing site sends users to reach the product (their tenant domain). In dev the
# product runs at http://<domain>:3000; in prod set scheme=https and leave the port empty.
NEXT_PUBLIC_PRODUCT_SCHEME=http
NEXT_PUBLIC_PRODUCT_PORT=3000
# Where the product app links back to for marketing/register.
NEXT_PUBLIC_WEBSITE_URL=http://saga.test:3001
# Exact-match origins; any origin matching CORS_ALLOWED_ORIGIN_REGEX is also allowed (default
# in code: any mapped .test tenant domain + localhost on any port — see scripts/dev-domains.sh).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOWED_ORIGIN_REGEX=^http://([a-z0-9-]+\.)*(test|localhost)(:\d+)?$

AICREDITS_API_KEY=sk-your-aicredits-key
AICREDITS_BASE_URL=https://api.aicredits.in/v1
AICREDITS_CHAT_MODEL=openai/gpt-4o-mini
AICREDITS_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.25
RETRIEVAL_MIN_CONTEXT_CHUNKS=2

FILEBASE_ACCESS_KEY=your-filebase-access-key
FILEBASE_SECRET_KEY=your-filebase-secret-key
FILEBASE_BUCKET_NAME=your-filebase-bucket
FILEBASE_ENDPOINT=https://s3.filebase.io
