{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "POSTGRES_DB",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_PORT",
    "API_PORT",
    "WEB_PORT",
    "WEBSITE_PORT",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_PRODUCT_SCHEME",
    "NEXT_PUBLIC_PRODUCT_PORT",
    "NEXT_PUBLIC_WEBSITE_URL",
    "CORS_ALLOWED_ORIGINS",
    "CORS_ALLOWED_ORIGIN_REGEX",
    "ENFORCE_LOGIN_ORIGIN",
    "LOGIN_ORIGIN_DEV_BYPASS",
    "HANDOFF_CODE_TTL_SECONDS",
    "JWT_SECRET",
    "ACCESS_TOKEN_TTL_SECONDS",
    "REFRESH_TOKEN_TTL_SECONDS",
    "TENANCY_DEFAULT_FALLBACK",
    "CACHE_URL",
    "AICREDITS_API_KEY",
    "AICREDITS_BASE_URL",
    "AICREDITS_CHAT_MODEL",
    "AICREDITS_EMBEDDING_MODEL",
    "EMBEDDING_DIMENSIONS",
    "CHUNK_SIZE_TOKENS",
    "CHUNK_OVERLAP_TOKENS",
    "RETRIEVAL_TOP_K",
    "RETRIEVAL_SCORE_THRESHOLD",
    "RETRIEVAL_MIN_CONTEXT_CHUNKS",
    "FILEBASE_ACCESS_KEY",
    "FILEBASE_SECRET_KEY",
    "FILEBASE_BUCKET_NAME",
    "FILEBASE_ENDPOINT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
